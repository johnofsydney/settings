#!/usr/bin/env bash
#
# delete-finished-branches — review and delete local git branches, SAFELY.
#
# Safety-first replacement for the old "force-delete everything" script:
#   - Dry-run by default: prints a status table and does NOTHING until asked.
#   - Classifies every branch (merged into main? has a remote? open/merged PR?
#     unpushed local-only commits?) and recommends an action, colour-coded.
#   - Never force-deletes a branch that has an OPEN PR, or commits that live
#     nowhere but locally, without an explicit typed confirmation.
#   - Protected mainlines, the current branch, and worktree-checked-out
#     branches are always skipped.
#   - Every deletion is logged (name + sha) to .git/deleted-branches.log and a
#     ready-to-paste restore command is printed, so a mistake is one paste to undo.
#
# Project-agnostic; run from any git repo.
#
# Usage:
#   delete-finished-branches                # dry-run: show the table, do nothing
#   delete-finished-branches --merged       # delete only clearly-merged branches, local only (one confirm)
#   delete-finished-branches -i             # interactive: decide each branch, and — only when the
#                                           #   remote copy is yours — offer to delete origin/<branch> too
#   delete-finished-branches -h
#
# Config (override via env):
#   PROTECTED_BRANCHES   pipe-separated regex of branches to keep
#                        (default: main|master|staging|qa|develop)
#
set -euo pipefail

protected="${PROTECTED_BRANCHES:-main|master|staging|qa|develop}"

# ---- flags -----------------------------------------------------------------
mode="dryrun"          # dryrun | merged | interactive
assume_yes=0
while [ $# -gt 0 ]; do
  case "$1" in
    -i | --interactive) mode="interactive" ;;
    --merged)           mode="merged" ;;
    -y | --yes)         assume_yes=1 ;;
    -h | --help)        sed -n '3,28p' "$0"; exit 0 ;;
    *) echo "unknown option: $1 (try -h)" >&2; exit 2 ;;
  esac
  shift
done

# ---- colours (only when writing to a terminal) -----------------------------
if [ -t 1 ]; then
  R=$'\033[31m'; G=$'\033[32m'; Y=$'\033[33m'; DIM=$'\033[2m'; BOLD=$'\033[1m'; X=$'\033[0m'
else
  R=""; G=""; Y=""; DIM=""; BOLD=""; X=""
fi

# ---- guards ----------------------------------------------------------------
git rev-parse --git-dir >/dev/null 2>&1 || { echo "Not a git repo." >&2; exit 1; }
current="$(git symbolic-ref --quiet --short HEAD || true)"
gitdir="$(git rev-parse --git-dir)"
log="$gitdir/deleted-branches.log"

# Mainline to test "merged into" against: first of these that exists.
mainline=""
for cand in origin/main origin/master main master; do
  git rev-parse --verify --quiet "$cand" >/dev/null && { mainline="$cand"; break; }
done
[ -n "$mainline" ] || { echo "No main/master ref found to compare against." >&2; exit 1; }

# ---- gather shared context once (avoid per-branch network calls) -----------
# Branches currently checked out in a worktree — git will refuse to delete these.
wt_branches="$(git worktree list --porcelain | awk '/^branch /{sub("refs/heads/","",$2); print $2}')"

echo "${DIM}▶ querying origin…${X}" >&2
remote_heads="$(git ls-remote --heads origin 2>/dev/null | sed -E 's#.*refs/heads/##' || true)"

merged_pr_heads=""; open_pr_map=""; pr_author_map=""; me_login=""
me_email="$(git config user.email || true)"
if command -v gh >/dev/null 2>&1; then
  echo "${DIM}▶ querying pull requests…${X}" >&2
  me_login="$(gh api user --jq .login 2>/dev/null || true)"
  merged_pr_heads="$(gh pr list --state merged --limit 1000 --json headRefName --jq '.[].headRefName' 2>/dev/null || true)"
  open_pr_map="$(gh pr list --state open --limit 1000 --json headRefName,number --jq '.[] | "\(.headRefName)\t\(.number)"' 2>/dev/null || true)"
  pr_author_map="$(gh pr list --state all --limit 1000 --json headRefName,author --jq '.[] | "\(.headRefName)\t\(.author.login)"' 2>/dev/null || true)"
fi

in_list()        { printf '%s\n' "$2" | grep -qxF "$1"; }
open_pr_for()    { printf '%s\n' "$open_pr_map"    | awk -F'\t' -v b="$1" '$1==b{print $2; exit}'; }
pr_author_for()  { printf '%s\n' "$pr_author_map"  | awk -F'\t' -v b="$1" '$1==b{print $2; exit}'; }

# "Mine" = safe to delete the REMOTE copy. If a PR exists, ownership is its author;
# otherwise the branch is mine only if every commit unique to it was authored by me.
# Anything ambiguous returns non-zero (not mine) so we never delete someone else's remote.
is_mine() {   # branch tip
  local b="$1" tip="$2" author authors
  author="$(pr_author_for "$b")"
  if [ -n "$author" ]; then
    [ -n "$me_login" ] && [ "$author" = "$me_login" ]; return
  fi
  authors="$(git log --format='%ae' "$mainline..$tip" 2>/dev/null || true)"
  [ -z "$authors" ] && authors="$(git log -1 --format='%ae' "$tip" 2>/dev/null || true)"
  [ -n "$authors" ] && [ -n "$me_email" ] || return 1
  ! printf '%s\n' "$authors" | grep -vqxF "$me_email"   # mine iff no other author appears
}

# ---- classify + print the table --------------------------------------------
declare -a C_NAME C_SHA C_CLASS C_REMOTE C_MINE   # collected deletion candidates (non-skipped)

printf "\n${BOLD}%-2s %-58s %-7s %-7s %-13s %s${X}\n" "" "BRANCH" "MERGED" "REMOTE" "PR" "RECOMMENDATION"
printf "${DIM}%s${X}\n" "$(printf '%.0s─' $(seq 1 110))"

while IFS= read -r b; do
  [ -n "$b" ] || continue
  sha="$(git rev-parse "$b")"

  # Skip reasons (never candidates).
  reason=""
  if printf '%s' "$b" | grep -qE "^(${protected})$"; then reason="protected"
  elif [ "$b" = "$current" ]; then reason="current branch"
  elif in_list "$b" "$wt_branches"; then reason="in a worktree"
  fi
  if [ -n "$reason" ]; then
    printf "${DIM}%-2s %-58s %-7s %-7s %-13s skip: %s${X}\n" "·" "$b" "" "" "" "$reason"
    continue
  fi

  if git merge-base --is-ancestor "$sha" "$mainline" 2>/dev/null; then merged_main=1; else merged_main=0; fi
  if in_list "$b" "$remote_heads"; then has_remote=1; else has_remote=0; fi
  if in_list "$b" "$merged_pr_heads"; then merged_pr=1; else merged_pr=0; fi
  openpr="$(open_pr_for "$b")"

  if [ "$has_remote" = 1 ]; then
    risk="$(git rev-list --count "origin/$b..$sha" 2>/dev/null || echo 0)"   # local commits not on origin
  else
    risk="$(git rev-list --count "$mainline..$sha" 2>/dev/null || echo 0)"   # commits not in mainline
  fi

  if   [ -n "$openpr" ];                            then cls=OPENPR
  elif [ "$merged_main" = 1 ];                      then cls=MERGED
  elif [ "$merged_pr" = 1 ];                        then cls=PRMERGED
  elif [ "$has_remote" = 1 ] && [ "$risk" = 0 ];    then cls=PUSHED
  else                                                   cls=UNMERGED
  fi

  case "$cls" in
    MERGED)   col=$G; dot="●"; reco="safe · merged into ${mainline#origin/}" ;;
    PRMERGED) col=$G; dot="●"; reco="safe · PR merged (squash)" ;;
    PUSHED)   col=$Y; dot="●"; reco="ok · pushed to origin, recoverable" ;;
    OPENPR)   col=$R; dot="▲"; reco="KEEP · open PR #$openpr — deleting closes it" ;;
    UNMERGED) col=$R; dot="▲"; reco="KEEP · $risk commit(s) only here, not on any remote" ;;
  esac

  if is_mine "$b" "$sha"; then mine=1; else mine=0; fi

  m_txt=$([ "$merged_main" = 1 ] && echo yes || echo no)
  if   [ "$has_remote" = 0 ]; then r_txt="-"
  elif [ "$mine" = 1 ];       then r_txt="origin"
  else                             r_txt="theirs"; reco="$reco · local only (remote is not yours)"; fi
  if   [ -n "$openpr" ];        then p_txt="#$openpr open"
  elif [ "$merged_pr" = 1 ];    then p_txt="merged"
  else                               p_txt="-"; fi

  printf "${col}%-2s${X} %-58s %-7s %-7s %-13s ${col}%s${X}\n" "$dot" "$b" "$m_txt" "$r_txt" "$p_txt" "$reco"

  C_NAME+=("$b"); C_SHA+=("$sha"); C_CLASS+=("$cls"); C_REMOTE+=("$has_remote"); C_MINE+=("$mine")
done < <(git for-each-ref --format='%(refname:short)' refs/heads/)

echo
echo "${DIM}Legend: ${G}● safe${X}${DIM} to delete · ${Y}● pushed${X}${DIM} (recoverable) · ${R}▲ keep${X}${DIM} (confirm required)${X}"

# ---- deletion helpers ------------------------------------------------------
declare -a RESTORE
# Delete the local branch only. Returns non-zero if the delete failed, so callers
# can gate the follow-up remote prompt on a successful local delete.
do_delete() {   # name sha
  local name="$1" sha="$2"
  if git branch -d "$name" >/dev/null 2>&1 || git branch -D "$name" >/dev/null 2>&1; then
    printf '%s  %s  %s\n' "$(date '+%F %T')" "$name" "$sha" >> "$log"
    RESTORE+=("git branch $name $sha")
    echo "  ${G}✓ deleted local${X} $name ${DIM}(was ${sha:0:9})${X}"
    return 0
  else
    echo "  ${R}✗ could not delete${X} $name"; return 1
  fi
}

# Offer to delete the origin copy — ONLY when it's yours. Called after a
# successful local delete; a remote that isn't yours is kept and reported.
offer_remote() {   # index
  local i="$1" name="${C_NAME[$1]}" sha="${C_SHA[$1]}"
  [ "${C_REMOTE[$i]}" = 1 ] || return 0
  if [ "${C_MINE[$i]}" != 1 ]; then
    echo "  ${DIM}• kept remote${X} origin/$name ${DIM}(not yours — local deleted only)${X}"
    return 0
  fi
  confirm "  also delete remote origin/$name (yours)?" || { echo "  ${DIM}• kept remote${X} origin/$name"; return 0; }
  if git push origin --delete "$name" >/dev/null 2>&1; then
    RESTORE+=("git push origin $sha:refs/heads/$name")
    echo "  ${G}✓ deleted remote${X} origin/$name"
  else
    echo "  ${Y}! could not delete remote${X} origin/$name"
  fi
}

print_restore_hint() {
  [ "${#RESTORE[@]}" -gt 0 ] || return 0
  echo
  echo "${BOLD}Restore any of these with:${X}"
  printf '  %s\n' "${RESTORE[@]}"
  echo "${DIM}(also appended to $log)${X}"
}

confirm() {   # prompt -> 0 if yes
  [ "$assume_yes" = 1 ] && return 0
  local ans; read -r -p "$1 [y/N] " ans || ans=""
  case "$ans" in [yY] | [yY][eE][sS]) return 0 ;; *) return 1 ;; esac
}

# ---- act -------------------------------------------------------------------
total="${#C_NAME[@]}"

case "$mode" in
  dryrun)
    echo
    echo "Dry-run only — nothing deleted. Choose how to proceed:"
    echo "  ${BOLD}delete-finished-branches --merged${X}   delete the ${G}safe${X} (merged) branches locally, one confirm"
    echo "  ${BOLD}delete-finished-branches -i${X}         review each branch; when the remote is yours, offer to delete origin too"
    ;;

  merged)
    idx=()
    for i in "${!C_NAME[@]}"; do
      case "${C_CLASS[$i]}" in MERGED | PRMERGED) idx+=("$i") ;; esac
    done
    if [ "${#idx[@]}" -eq 0 ]; then echo; echo "No merged branches to delete."; exit 0; fi
    echo
    echo "${BOLD}Will delete these ${#idx[@]} merged branch(es)${X} (local only — use ${BOLD}-i${X} to also drop the origin copy):"
    for i in "${idx[@]}"; do echo "  ${G}●${X} ${C_NAME[$i]}"; done
    echo
    if confirm "Proceed?"; then
      for i in "${idx[@]}"; do do_delete "${C_NAME[$i]}" "${C_SHA[$i]}"; done
      print_restore_hint
    else
      echo "Aborted."
    fi
    ;;

  interactive)
    [ "$total" -eq 0 ] && { echo; echo "No deletable branches."; exit 0; }
    echo
    echo "Interactive — for each: [d]elete  [s]kip  [q]uit. Risky ones need the name typed."
    echo "${DIM}After a local delete, if the origin copy is yours you'll be asked before it's removed.${X}"
    for i in "${!C_NAME[@]}"; do
      b="${C_NAME[$i]}"; cls="${C_CLASS[$i]}"
      echo
      echo "  ${BOLD}$b${X}  ${DIM}(${cls})${X}"
      case "$cls" in
        OPENPR | UNMERGED)
          echo "  ${R}⚠ risky${X} — this would lose work or close a PR."
          ans=""; read -r -p "  type the branch name to delete, or Enter to skip: " ans || ans=""
          if [ "$ans" = "$b" ]; then do_delete "$b" "${C_SHA[$i]}" && offer_remote "$i"; else echo "  skipped."; fi
          ;;
        *)
          ans=""; read -r -p "  [d]elete / [s]kip / [q]uit: " ans || ans=""
          case "$ans" in
            d | D) do_delete "$b" "${C_SHA[$i]}" && offer_remote "$i" ;;
            q | Q) break ;;
            *)     echo "  skipped." ;;
          esac
          ;;
      esac
    done
    print_restore_hint
    ;;
esac
